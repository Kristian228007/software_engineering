      "item": [
        {
          "name": "Create user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 or 409', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "if (pm.response.code === 201) {",
                  "    pm.test('Response has id and login', function () {",
                  "        pm.expect(json).to.have.property('id');",
                  "        pm.expect(json).to.have.property('login');",
                  "        pm.expect(json.login).to.eql(pm.collectionVariables.get('login'));",
                  "    });",
                  "    pm.collectionVariables.set('userId', json.id);",
                  "}",
                  "",
                  "if (pm.response.code === 409) {",
                  "    pm.test('Conflict response has error', function () {",
                  "        pm.expect(json).to.have.property('error');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
